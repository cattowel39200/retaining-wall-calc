{
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "functions": {
    "api/*.py": {
      "runtime": "@vercel/python@4.5.0",
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/api/calculate", "dest": "/api/calculate.py" },
    { "src": "/api/section-image", "dest": "/api/section_image.py" },
    { "src": "/api/rebar-image", "dest": "/api/rebar_image.py" },
    { "src": "/api/report", "dest": "/api/report.py" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
